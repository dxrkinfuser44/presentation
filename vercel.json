{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "devCommand": "npm run dev",
  "installCommand": "npm ci",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/html/(.*)",
      "destination": "/html/$1"
    },
    {
      "source": "/api/manifest.json",
      "destination": "/api/manifest.json"
    },
    {
      "source": "/api/spec.json",
      "destination": "/api/spec.json"
    },
    {
      "source": "/api/agent-guide.json",
      "destination": "/api/agent-guide.json"
    },
    {
      "source": "/api/presentation/(.*)",
      "destination": "/api/presentation/$1"
    },
    {
      "source": "/llms.txt",
      "destination": "/llms.txt"
    },
    {
      "source": "/.well-known/(.*)",
      "destination": "/.well-known/$1"
    },
    {
      "source": "/((?!api|_next/static|_next/image|favicon.ico|\\.well-known|llms.txt|lib|src|node_modules|\\.(js|css|png|jpg|jpeg|gif|svg|ico|json|txt|html|map)$).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/html/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600"
        }
      ]
    }
  ]
}
